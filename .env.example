# EduSphere LMS — Environment Variables Configuration Example

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edusphere_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_APP_USER=edusphere_app
DB_APP_PASSWORD=edusphere_password

# Optional: Remote database URL
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?sslmode=require
# DB_SSL=true

# Supabase hint:
# Use the Supabase connection string from Project Settings → Database → Connection string.
# Keep the database URL server-side only.

# Optional: Backend URL for Vercel frontend proxy
# BACKEND_URL=http://localhost:3000
# JWT Settings
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Server Settings
PORT=3000
NODE_ENV=development

# Anthropic Claude API Key
# Get a key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
