# EduSphere LMS — Environment Variables Configuration Example
PORT=3000
NODE_ENV=development

# Database Settings (Local Embedded PG defaults to port 5433)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=edusphere_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_APP_USER=edusphere_app
DB_APP_PASSWORD=edusphere_password

# Remote/Supabase Database URL (If set, start.js will bypass local PG)
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JSON Web Token Secret Keys
JWT_SECRET=edusphere_jwt_secret_amala_hss_2026_very_secure_key
JWT_EXPIRES_IN=7d

# Anthropic Claude API Key (Required for AI features)
# Get a key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
